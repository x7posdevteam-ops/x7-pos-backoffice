# Backend API base URL (use proxy in dev via vite.config.ts, or set full URL for production)
VITE_API_URL=/api

# External support / help portal (opens in a new tab from login header and footer)
VITE_SUPPORT_URL=https://support.x7pos.com

# Legal pages (open in a new tab from onboarding)
VITE_PRIVACY_URL=https://x7pos.com/privacy
VITE_TERMS_URL=https://x7pos.com/terms
